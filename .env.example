# ─────────────────────────────────────────────────────────────────────────────
# Quovi — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs réelles.
# Ce fichier est versionné, .env.local ne l'est pas (cf .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
# URL publique de l'app (sans slash final). Sert aux callbacks (Stripe, emails,
# liens de signature). Dev: http://localhost:3000 — Prod: https://quovi.fr
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (auth + base de données) ───────────────────────────────────────
# À récupérer dans : Dashboard Supabase → Project Settings → API
# URL du projet (publique).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Clé "anon public" — exposée côté client, sécurisée par les RLS policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Clé "service_role" — SECRÈTE, bypasse les RLS. Jamais exposée au client.
# Utilisée côté serveur uniquement (lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe (paiement & abonnements) ─────────────────────────────────────────
# À récupérer dans : Dashboard Stripe → Developers → API keys
# Clé secrète serveur (sk_test_... en sandbox, sk_live_... en prod).
STRIPE_SECRET_KEY=sk_test_your-key-here
# Secret du webhook (Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret).
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
# IDs des prix mensuels (Stripe → Products → sélectionner le prix → API ID, format price_...).
STRIPE_STARTER_MONTHLY_PRICE_ID=price_your-starter-id
STRIPE_PRO_MONTHLY_PRICE_ID=price_your-pro-id

# ── Anthropic (IA : chatbot + génération de devis) ──────────────────────────
# À récupérer sur : https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Resend (emails transactionnels : envoi de devis, relances, signatures) ──
# À récupérer sur : https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here

# ── Yousign (signature électronique conforme eIDAS) ─────────────────────────
# À récupérer sur : Yousign → Espace développeur → API keys
YOUSIGN_API_KEY=your-yousign-key-here
# "true" pour utiliser le sandbox Yousign, "false" pour la prod.
YOUSIGN_SANDBOX=true

# ── Cron (auth des endpoints planifiés) ─────────────────────────────────────
# Token aléatoire à générer (ex: `openssl rand -hex 32`).
# Utilisé en header `Authorization: Bearer <token>` pour authentifier
# les jobs cron (Netlify Scheduled Functions) sur /api/trial.
CRON_SECRET=your-random-token-here
